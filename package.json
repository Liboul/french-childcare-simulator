{
  "name": "agent-comparatif-modes-de-garde",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src harness scripts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "ci": "bun run typecheck && bun run lint && bun run format && bun run test",
    "demo:scenario": "bun run scripts/run-demo-scenario.ts",
    "harness:serve": "bun run harness/server.ts",
    "build:harness-skill-runner": "bun run scripts/build-harness-skill-runner.ts",
    "package:harness-skill": "bun run scripts/package-harness-skill.ts",
    "setup:cursor-harness-skill": "bun run scripts/setup-cursor-harness-skill.ts",
    "schema:scenario": "bun run scripts/generate-scenario-json-schema.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.7"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
